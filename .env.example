HOST=127.0.0.1
PORT=3000

# TikTok Developers app credentials.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Must match the redirect URI configured in TikTok Developers.
# Local example:
TIKTOK_REDIRECT_URI=http://127.0.0.1:3000/oauth/callback

# Scopes requested during owner login.
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.list

# Optional: use existing tokens instead of /oauth/start.
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_REFRESH_TOKEN=
# TIKTOK_ACCESS_TOKEN_EXPIRES_AT=

